{
  "defaults": {
    "allow_prerelease": false,
    "fallback_to_tags": true,
    "update_version": true,
    "commit_strategy": "release_latest",
    "version_strategy": "release_latest"
  },
  "tools": {
    "mkSolcSelect": {
      "repo": "crytic/solc-select",
      "commit_strategy": "branch_head",
      "branch": "dev"
    },
    "mkCryticCompile": {
      "repo": "crytic/crytic-compile"
    },
    "mkSlither": {
      "repo": "crytic/slither"
    },
    "mkCloudexec": {
      "repo": "crytic/cloudexec"
    },
    "mkMedusa": {
      "repo": "crytic/medusa"
    },
    "mkEchidna": {
      "repo": "crytic/echidna",
      "update_version": false
    },
    "mkMewt": {
      "repo": "trailofbits/mewt"
    },
    "mkMuton": {
      "repo": "trailofbits/muton"
    },
    "mkNecessist": {
      "repo": "trailofbits/necessist"
    },
    "mkRoundme": {
      "repo": "crytic/roundme"
    }
  }
}
